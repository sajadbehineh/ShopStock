@model ShopStock.Web.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "ورود به سایت";
}

<!-- start of auth-container -->
<div class="auth-container">
    <div class="auth-title mb-3">ورود به سایت</div>
    <!-- start of auth-box -->
    <div class="auth-box ui-box">
        <!-- start of auth-form -->
        <form asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            <!-- start of form-element -->
            <div class="form-element-row mb-3">
                <input asp-for="UserNameOrEmail" dir="ltr" class="form-control rtl-placeholder" placeholder="نام کاربری یا ایمیل را وارد کنید">
            </div>
            <div class="form-element-row mb-3">
                <input asp-for="Password" dir="ltr" class="form-control rtl-placeholder" placeholder="کلمه عبور را وارد کنید">
            </div>
            @if (ViewBag.EmailNotActivated == true)
            {
                <div class="alert alert-warning" role="alert">
                    حساب شما فعال نیست. لطفا ایمیل خود را تایید کنید.
                </div>
            }
            <div class="form-element-row mb-3">
                <div class="remember-me">
                    <input asp-for="RememberMe" />
                    <label asp-for="RememberMe">
                        مرا به خاطر بسپار
                    </label>
                </div>
            </div>
            <!-- end of form-element -->
            <!-- start of form-element -->
            <div class="form-element-row mb-3">
                <button class="btn btn-primary">ورود</button>
            </div>
            <!-- end of form-element -->
            <!-- start of form-element -->
            <div class="form-element-row">
                <div class="mb-3">
                    <a href="#" class="link">کلمه عبور خود را فراموش کرده‌ام!</a>
                </div>
                <div class="mb-3">
                    با ورود و یا ثبت نام در سایت شما
                    <a href="#" class="link">
                        شرایط و
                        قوانین
                    </a> استفاده
                    از تمام سرویس های
                    سایت و <a href="#" class="link">قوانین حریم خصوصی</a> آن را می‌پذیرید.
                </div>
                <div asp-validation-summary="All" class="text-danger"></div>
            </div>
            <!-- end of form-element -->
        </form>
        <!-- end of auth-form -->
    </div>
    <!-- end of auth-box -->
</div>
<!-- start of auth-container -->
@section Script
{
    <partial name="_ValidationScriptsPartial" />
}
