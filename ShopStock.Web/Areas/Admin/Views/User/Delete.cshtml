@model ShopStock.Web.Areas.Admin.ViewModels.User.DeleteUserViewModel
<div class="container-xxl flex-grow-1">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card mb-4">
                <h5 class="card-header">اطلاعات کاربر جهت حذف</h5>
                <div class="card-body">
                    <div class="d-flex align-items-start align-items-sm-center gap-4">
                        <!-- آواتار -->

                        <img src="/Storage/ProfilePictures/@Model.ProfilePicture" id="uploadedAvatar"
                             height="120" width="120" alt="Avatar" class="d-block rounded shadow-sm"
                             style="object-fit: cover; border: 3px solid #fff;">

                        <!-- اطلاعات متنی -->
                        <div class="button-wrapper">
                            <h4 class="fw-bold mb-2">@Model.FirstName @Model.LastName</h4>
                            <p class="text-muted mb-3">
                                <i class="bx bx-user me-1"></i> نام کاربری: <span dir="ltr" class="fw-semibold">@@@Model.UserName</span>
                            </p>

                            <div class="d-flex flex-wrap gap-2">
                                @if (Model.Roles.Any())
                                {
                                    @foreach (var role in Model.Roles)
                                    {
                                        <span class="badge bg-label-info">
                                            <i class="bx bx-shield-quarter me-1"></i> @role
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-label-secondary">بدون نقش</span>
                                }
                            </div>
                        </div>
                    </div>


                    <div class="alert alert-danger mt-4">
                        <h6 class="alert-heading fw-bold">هشدار!</h6>
                        آیا از حذف این کاربر مطمئن هستید؟ این عملیات قابل بازگشت نیست.
                    </div>

                    <!-- دکمه‌ای که مودال را باز می‌کند -->
                    <div class="d-flex justify-content-start gap-2 mt-3">
                        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#confirmDeleteModal">
                            <i class="bx bx-trash me-1"></i> حذف کاربر
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">انصراف</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="confirmDeleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">تایید نهایی حذف</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    با تایید این عملیات، کاربر <strong>@Model.UserName</strong> از سیستم حذف خواهد شد. ادامه می‌دهید؟
                </div>
                <div class="modal-footer" dir="ltr">
                    <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">انصراف</button>
                    <!-- فرم حذف -->
                    <form asp-action="Delete" id="deleteForm">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger">بله، حذف کن</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
