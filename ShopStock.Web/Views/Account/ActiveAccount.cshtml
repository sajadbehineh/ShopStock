@{
    ViewData["Title"] = "فعال‌سازی حساب کاربری";
    bool isSuccess = ViewBag.ActivationResult ?? false;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="card-body text-center p-5">

                    @if (isSuccess)
                    {
                        <!-- Success State -->
                        <div class="mb-4">
                            <i class="bi bi-check-circle-fill text-success d-flex align-items-center justify-content-center"
                               style="font-size:60px;line-height:1;"></i>
                        </div>

                        <h1 class="fw-bold text-success mb-3">
                            حساب شما فعال شد
                        </h1>

                        <p class="lead text-muted mb-4">
                            ایمیل شما با موفقیت تأیید شد و حساب کاربری اکنون فعال است.
                        </p>

                        <div class="alert alert-success border-0">
                            اکنون می‌توانید وارد حساب کاربری خود شوید و از تمامی امکانات سایت استفاده کنید.
                        </div>

                        <a @* asp-controller="Account"
                           asp-action="Login" *@
                            class="btn btn-success btn-lg px-5">
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            ورود به حساب کاربری
                        </a>
                    }
                    else
                    {
                        <!-- Error State -->
                        <div class="mb-4">
                            <i class="bi bi-x-circle-fill text-danger d-flex align-items-center justify-content-center"
                               style="font-size:60px;line-height:1;"></i>
                        </div>

                        <h1 class="fw-bold text-danger mb-3">
                            فعال‌سازی ناموفق بود
                        </h1>

                        <p class="lead text-muted mb-4">
                            کد فعال‌سازی معتبر نیست یا حساب کاربری قبلاً فعال شده است.
                        </p>

                        <div class="alert alert-danger border-0">
                            در صورتی که لینک فعال‌سازی منقضی شده باشد، می‌توانید درخواست ارسال مجدد ایمیل فعال‌سازی را ثبت کنید.
                        </div>

                        <div class="d-flex justify-content-center gap-2 flex-wrap">
                            <a asp-controller="Account"
                               asp-action="Register"
                               class="btn btn-outline-primary">
                                ثبت نام مجدد
                            </a>

                            <a asp-controller="Account"
                               asp-action="Login"
                               class="btn btn-primary">
                                ورود به حساب کاربری
                            </a>
                        </div>
                    }

                </div>

                <div class="card-footer bg-light text-center py-3">
                    <small class="text-muted">
                        ShopStock © @DateTime.Now.Year
                    </small>
                </div>

            </div>

        </div>
    </div>

</div>
