else
{
    <div class="user-options user-options--guest">
        <!-- Auth Links (visible, no dropdown) -->
        <div class="user-option user-option--auth-links">
            @{
                // ۱. خواندن مسیر فعلی مرورگر
                var currentPath = Context.Request.Path.Value ?? "";

                // ۲. بررسی اینکه آیا کاربر هم‌اکنون در صفحات مربوط به فرآیند احراز هویت قرار دارد یا خیر
                bool isAuthPage = currentPath.StartsWith("/Login", StringComparison.OrdinalIgnoreCase) ||
                                  currentPath.StartsWith("/Register", StringComparison.OrdinalIgnoreCase) ||
                                  currentPath.StartsWith("/RegistrationSuccess", StringComparison.OrdinalIgnoreCase);

                string finalReturnUrl = null;

                if (!isAuthPage)
                {
                    // اگر در یک صفحه معمولی (مثل دکمه یک محصول) است، آدرس فعلی را بردار
                    finalReturnUrl = Context.Request.Path + Context.Request.QueryString;
                }
                else if (Context.Request.Query.TryGetValue("returnUrl", out var existingUrl))
                {
                    // اگر در صفحات لاگین/ثبت‌نام/موفقیت است، بررسی کن آیا از قبل آدرسی (مثل ادمین) در URL وجود دارد؟ اگر بله، همان را حفظ کن
                    finalReturnUrl = existingUrl;
                }
            }

            <a asp-controller="Account"
               asp-action="Login"
               asp-route-returnUrl="@finalReturnUrl"
               class="auth-link auth-link--login">
                ورود
            </a>

            <span class="auth-divider">|</span>

            <a asp-controller="Account"
               asp-action="Register"
               asp-route-returnUrl="@finalReturnUrl"
               class="auth-link auth-link--register">
                ثبت‌نام
            </a>
        </div>

        <!-- Wishlist -->
        <div class="user-option">
            <a asp-controller="Account"
               asp-action="Login"
               asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")"
               class="user-option-btn user-option-btn--account"
               title="برای مشاهده علاقه‌مندی‌ها وارد شوید">
                <i class="ri-heart-3-fill icon"></i>
                <span class="counter">۰</span>
            </a>
        </div>

        <!-- Cart -->
        <div class="user-option user-option--cart">
            <a href="cart.html" class="user-option-btn user-option-btn--cart">
                <i class="ri-shopping-bag-2-fill icon"></i>
                <span class="user-item-text">
                    <span class="title">سبد خرید شما</span>
                    <span class="value fa-num">83,678,000 <span class="currency">تومان</span></span>
                </span>
                <span class="counter">۴</span>
            </a>

            <div class="mini-cart">
                <div class="mini-cart-header">
                    <span class="mini-cart-products-count fa-num">4 کالا</span>
                    <a href="cart.html" class="btn btn-link px-0">
                        مشاهده سبد خرید <i class="ri-arrow-left-s-fill"></i>
                    </a>
                </div>

                <!-- لیست محصولات مینی‌کارت -->

                <div class="mini-cart-footer">
                    <div class="mini-cart-total">
                        <span class="mini-cart-total-label">مبلغ قابل پرداخت:</span>
                        <span class="mini-cart-total-value fa-num">
                            83,678,000 <span class="currency">تومان</span>
                        </span>
                    </div>
                    <a asp-controller="Account"
                       asp-action="Login"
                       asp-route-returnUrl="@($"{Context.Request.Path}{Context.Request.QueryString}")"
                       class="btn btn-primary">
                        ورود و ثبت سفارش
                    </a>
                </div>
            </div>
        </div>
    </div>
}

