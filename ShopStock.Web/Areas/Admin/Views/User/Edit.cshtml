@model ShopStock.Web.Areas.Admin.ViewModels.User.EditUserViewModel

@{
    ViewData["Title"] = "ویرایش کاربر";

    var profilePicture = string.IsNullOrWhiteSpace(Model.CurrentProfilePictureName)
        ? "NoPhoto.jpg"
        : Model.CurrentProfilePictureName;

    var profilePicturePath = $"/Storage/ProfilePictures/{profilePicture}";
}

@* نمایش پیام خطای ویرایش *@
@if (TempData["FailedMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible mb-4" role="alert">
        @TempData["FailedMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["RoleRequiredMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible mb-4" role="alert">
        @TempData["RoleRequiredMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="Edit" enctype="multipart/form-data" method="post">

    <input asp-for="Id" type="hidden" />
    <input asp-for="CurrentProfilePictureName" type="hidden" />
    @* <input asp-for="RemoveProfilePicture" type="hidden" class="remove-profile-picture-input preview-delete-marker" /> *@

    <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

    <div class="row g-4 align-items-start">

        <!-- Left Panel -->
        <div class="col-12 col-lg-3 col-xxl-4">

            <div class="left-panel">

                <!-- Profile Picture -->
                <div class="card mb-4 preview-image-group">

                    <div class="card-header">
                        <h5 class="mb-0">تصویر پروفایل</h5>
                    </div>

                    <div class="card-body">

                        <div class="mb-4 d-flex justify-content-center">
                            <img class="rounded-circle img-thumbnail preview-box profile-preview shadow-sm border"
                                 src="@profilePicturePath"
                                 data-default-src="/Storage/ProfilePictures/NoPhoto.jpg">
                        </div>

                        <div class="form-group">

                            <label asp-for="ProfilePictureFile" class="form-label"></label>

                            <div class="input-group">

                                <input asp-for="ProfilePictureFile"
                                       class="form-control preview-input"
                                       type="file"
                                       accept="image/*">

                                <button type="button"
                                        class="btn btn-outline-danger preview-remove-btn">
                                    حذف عکس
                                </button>

                            </div>

                            <div class="form-text mt-2">
                                فرمت‌های مجاز: JPG, PNG
                            </div>

                            <div class="form-text mt-1 text-muted">
                                اگر تصویر جدیدی انتخاب نکنید، تصویر فعلی حفظ می‌شود.
                            </div>
                            
                            <span asp-validation-for="ProfilePictureFile"
                                  class="text-danger validation-message"></span>
                            <input type="hidden" class="preview-delete-marker" name="deleteCurrentPicture" value="false" />
                        </div>

                    </div>

                </div>


                <!-- Roles -->
                @if (Model.Roles != null && Model.Roles.Any())
                {
                    <div class="card">

                        <div class="card-header">
                            <h5 class="mb-0">نقش‌های کاربر</h5>
                        </div>

                        <div class="card-body roles-container">

                            <div class="row">

                                @foreach (var role in Model.Roles)
                                {
                                    <div class="col-md-6 mb-3">

                                        <div class="form-check custom-option custom-option-basic">

                                            <label class="form-check-label custom-option-content">

                                                <input class="form-check-input"
                                                       name="UserSelectedRoles"
                                                       type="checkbox"
                                                       value="@role.Id"
                                                @((Model.UserSelectedRoles != null && Model.UserSelectedRoles.Contains(role.Id)) ? "checked" : "")>

                                                <span class="custom-option-header">

                                                    <span class="h6 mb-0">
                                                        @role.RoleName
                                                    </span>

                                                </span>

                                            </label>

                                        </div>

                                    </div>
                                }

                            </div>

                        </div>

                    </div>
                }

            </div>

        </div>


        <!-- Form -->
        <div class="col-12 col-lg-9 col-xxl-8">

            <div class="card">

                <div class="card-header">
                    <h5 class="mb-0">ویرایش کاربر</h5>
                </div>

                <div class="card-body">
                    <div class="row g-4">

                        <div class="col-12 col-md-6">
                            <label asp-for="FirstName" class="form-label"></label>
                            <input asp-for="FirstName" class="form-control">
                            <span asp-validation-for="FirstName" class="text-danger validation-message"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="LastName" class="form-label"></label>
                            <input asp-for="LastName" class="form-control">
                            <span asp-validation-for="LastName" class="text-danger validation-message"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="UserName" class="form-label"></label>
                            <input asp-for="UserName" class="form-control">
                            <span asp-validation-for="UserName" class="text-danger validation-message"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control">
                            <span asp-validation-for="Email" class="text-danger validation-message"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Mobile" class="form-label"></label>
                            <input asp-for="Mobile" class="form-control">
                            <span asp-validation-for="Mobile" class="text-danger validation-message"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="NationalCode" class="form-label"></label>
                            <input asp-for="NationalCode" class="form-control">
                            <span asp-validation-for="NationalCode" class="text-danger validation-message"></span>
                        </div>

                        <div class="col-12 col-md-6">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control">
                            <div class="form-text mt-2">
                                اگر نمی‌خواهید رمز عبور تغییر کند، این فیلد را خالی بگذارید.
                            </div>
                            <span asp-validation-for="Password" class="text-danger validation-message"></span>
                        </div>

                        <div class="col-12 col-md-6 d-flex align-items-center">
                            <div class="form-check form-switch mt-0">
                                <input asp-for="IsActive" class="form-check-input">
                                <label asp-for="IsActive" class="form-check-label"></label>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="card-footer">

                    <div class="d-flex justify-content-end gap-2 flex-wrap">
                        
                        <button type="submit" class="btn btn-primary">
                            ذخیره تغییرات
                        </button>

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            بازگشت
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</form>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="~/js/plugins/image-upload-preview.js" asp-append-version="true"></script>
}
